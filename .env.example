# Copy this file to .env and fill in real values before running
# `docker compose up`. Never commit the real .env file.

# ── MySQL ──────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=ai_chatbot
MYSQL_USER=root
# Host port that maps to the container's 3306 (kept as 3307 to match the
# project's existing local-dev convention).
MYSQL_PORT=3307

# ── Ollama ─────────────────────────────────────────────────────────────────
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3.1:8b

# ── Backend (Flask) ────────────────────────────────────────────────────────
BACKEND_PORT=5001

# ── Frontend (nginx) ───────────────────────────────────────────────────────
FRONTEND_PORT=5173
